# ── vLLM ─────────────────────────────────────────────────────────────────────
VLLM_BASE_URL=http://vllm-server:8001/v1
VLLM_MODEL=Qwen/Qwen3-VL-8B-Instruct-FP8
VLLM_MAX_TOKENS=4096
VLLM_MAX_MODEL_LEN=12288
VLLM_TEMPERATURE=0.3
# ── Streaming + online hallucination abort ───────────────────────────────────
# Chỉ áp dụng cho VISION PRIMARY path (Qwen3-VL trên ảnh). Text-only fallback
# (sau PaddleOCR) LUÔN chạy blocking mode bất kể flag — input đã structured,
# detector dễ false-positive trên patterns lặp hợp lệ.
#
#
# VLLM_HALLU_STREAM_ENABLED         : kill-switch toàn cục. false → mọi path
#                                      dùng blocking (debug / so sánh A-B).
# VLLM_HALLU_STREAM_INTERVAL_CHARS  : check mỗi N chars. <100 bị clamp lên 100.
#                                      500 cân bằng: bắt loop sau ~1s decode,
#                                      cost ~5-10ms regex/check.
VLLM_HALLU_STREAM_ENABLED=true
VLLM_HALLU_STREAM_INTERVAL_CHARS=500

# ── Hallucination detector thresholds ────────────────────────────────────────
# Dùng cho CẢ online (streaming) lẫn offline (parsed dict) detector.
# Xem src/pipeline/hallucination_detector.py docstring để hiểu trade-off.
#
# HALLU_DUP_ITEM_RUN_MIN  : số item liên tiếp cùng tên (period=1 case) → loop
#                           signal. Default 7 — receipt thật hiếm khi có 7 dòng
#                           items y hệt nhau (thường được cashier gộp qty).
#                           Loosen 5 → bắt sớm hơn nhưng false-positive trên
#                           menu đồ uống set. Tighten 10 → an toàn cho duplicate
#                           hợp lệ, cho hallu chạy thêm ~1-2s trước khi abort.
# HALLU_CYCLE_MAX_PERIOD  : kích thước block tối đa khi quét cyclic loop
#                           period 2..N. Default 5 — phủ pattern AEON
#                           [item → KHUYẾN MÃI → CK THẺ] (period=3) + biến thể
#                           4-5 dòng. Detector cũ chỉ scan period=1 → mù hoàn
#                           toàn với 3 tên xen kẽ lặp lại (decoder loop AEON).
# HALLU_CYCLE_REPEATS_MIN : số lần block period≥2 lặp liên tiếp tối thiểu để
#                           flag loop. Default 3 — cyclic ≥2-period gần như
#                           không tồn tại hợp lệ ở repeats=3 trên receipt.
#                           Giảm 2 quá nhạy (AB,AB = 4 items hợp lệ bị flag).
# HALLU_CHAR_RUN_MIN      : số ký tự non-digit/non-ws lặp liên tiếp ("AAAAAA",
#                           "......"). Default 6 — đủ chặt để bỏ qua "MMMM"
#                           (4 chữ M trong brand name) nhưng bắt được decoder
#                           stuck phun ký tự đơn.
# HALLU_NGRAM_MAX_LEN     : quét cụm độ dài 2..N. Default 4 — bao phủ phần lớn
#                           loop pattern ("abcabc", "abcdabcd"). Tăng 5-6 thì
#                           cost regex tăng tuyến tính nhưng bắt thêm loop dài.
# HALLU_NGRAM_REPEAT_MIN  : số lần cụm n-gram lặp liên tiếp tối thiểu. Default
#                           4 — pattern "abcabcabcabc" (4×). Giảm 3 quá nhạy
#                           (pattern tự nhiên trong text bị flag), tăng 5-6
#                           bỏ sót loop ngắn.
#
HALLU_DUP_ITEM_RUN_MIN=8
HALLU_CYCLE_MAX_PERIOD=5
HALLU_CYCLE_REPEATS_MIN=3
HALLU_CHAR_RUN_MIN=10
HALLU_NGRAM_MAX_LEN=4
HALLU_NGRAM_REPEAT_MIN=6

# ── Image preprocessing (src/preprocessing) ─────────────────────────────────
# Config xử lý ảnh nằm ở src/preprocessing/defaults/default.yaml.
# Override qua env: PP2_<SECTION>_<KEY> (vd: PP2_FIT_ZOOM_TARGET_TEXT_H=32).
# Legacy alias vẫn đọc từ đây: VLLM_IMAGE_MIN/MAX_PIXELS (fit), PADDLE_DEVICE.

# ── Visual token cap (Qwen3-VL: 1 token = 32×32 px = 1024 px) ────────────────
# Trần/sàn DIỆN TÍCH gửi vLLM; cũng là alias cho preprocessing fit.min/max_pixels
# → 2 tầng resize đồng bộ, không double-resample.
VLLM_IMAGE_MIN_PIXELS=524288
VLLM_IMAGE_MAX_PIXELS=1310720

# ── Image-quality flags (metadata-only, ImageQualityConfig) ──────────────────
# Gắn khối `image_quality` vào response — báo downstream ảnh nguồn kém, KHÔNG
# can thiệp extract.
# - QUALITY_MIN_INPUT_SHORT_SIDE: cạnh NGẮN ảnh đầu vào < ngưỡng → low_res_input.
# - QUALITY_MIN_TEXT_HEIGHT_PX  : median cao chữ (poly, DPI nguồn) < ngưỡng →
#     low_legibility. Calibrate batch 24 ảnh (dải-hẹp không đọc 11.8-16.9px,
#     đọc tốt ≥19.9px). 0 = tắt.
QUALITY_MIN_INPUT_SHORT_SIDE=1200
QUALITY_MIN_TEXT_HEIGHT_PX=16.0

# ── PaddleOCR: device dùng chung ─────────────────────────────────────────────
# gpu (production) | cpu (dev không CUDA). Dùng cho CẢ preprocessing
# (services.device) lẫn fallback OCR bên dưới.
PADDLE_DEVICE=gpu

# ── PaddleOCR fallback OCR — namespace PADDLE_TEXT_* (PaddleTextConfig) ───────
# FULL det+rec pipeline cho fallback path khi VLM hallucinate / truncate / empty.
# Xem src/extraction/paddle_text.py docstring cho rationale từng knob.
PADDLE_TEXT_DET_MODEL=PP-OCRv5_server_det
PADDLE_TEXT_REC_MODEL=PP-OCRv5_server_rec
PADDLE_TEXT_LANG=vi
PADDLE_TEXT_USE_DOC_ORI=true
PADDLE_TEXT_USE_TEXTLINE_ORI=true
# UVDoc unwarping — heavy, dễ over-correct receipt phẳng → mặc định tắt.
PADDLE_TEXT_USE_DOC_UNWARPING=false
# Detection (DB) tuning cho receipt mờ + diacritic VN:
PADDLE_TEXT_DET_THRESH=0.3
PADDLE_TEXT_DET_BOX_THRESH=0.6
PADDLE_TEXT_DET_UNCLIP_RATIO=1.6
PADDLE_TEXT_DET_LIMIT_SIDE_LEN=2048
PADDLE_TEXT_DET_LIMIT_TYPE=max
# Post-processing & format:
PADDLE_TEXT_MIN_SCORE=0.6
PADDLE_TEXT_ROW_OVERLAP=0.9
PADDLE_TEXT_BBOX_QUANT=2

# ── Pipeline / Backpressure ──────────────────────────────────────────────────
# Concurrency = capacity semaphore. Khớp --max-num-seqs của vLLM.
GLOBAL_CONCURRENCY=12

# ── Timeout ──────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=360

# ── Upload guardrail ─────────────────────────────────────────────────────────
MAX_IMAGE_BYTES=50000000

# ── Postprocess: loại items / merchant_name theo từ khoá (đọc từ file) ───────
# Override đường dẫn qua env (tùy chọn):
# EXCLUDE_ITEM_PATTERNS_FILE=config/exclude_item_patterns.txt
# EXCLUDE_MERCHANT_PATTERNS_FILE=config/exclude_merchant_patterns.txt
